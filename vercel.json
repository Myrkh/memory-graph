{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "pnpm -r build",
  "outputDirectory": "packages/playground/dist",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "cleanUrls": true,
  "rewrites": [
    { "source": "/demo", "destination": "/index.html" },
    { "source": "/docs", "destination": "/index.html" },
    { "source": "/philosophy", "destination": "/index.html" }
  ]
}
