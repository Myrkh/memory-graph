{
  "manifest_version": 3,
  "name": "memory-graph",
  "version": "0.3.0",
  "description": "Your reading, visualized. Across every site.",
  "icons": {
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "permissions": ["sidePanel", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_title": "Open memory-graph"
  }
}
