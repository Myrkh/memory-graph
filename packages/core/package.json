{
  "name": "@myrkh/memory-graph",
  "version": "0.1.0",
  "description": "Visualize reading attention as a node-link graph. Multi-DOM · multi-strategy · smart defaults. React + TypeScript.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles": "./dist/styles/base.css",
    "./themes/stit-claude": "./dist/styles/themes/stit-claude.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Myrkh/memory-graph.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Myrkh/memory-graph#readme",
  "bugs": {
    "url": "https://github.com/Myrkh/memory-graph/issues"
  },
  "author": "Yoann Dumont",
  "license": "MIT",
  "scripts": {
    "build": "tsup && node scripts/build-styles.mjs",
    "build:styles": "node scripts/build-styles.mjs",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "keywords": [
    "react",
    "reading",
    "attention",
    "graph",
    "visualization",
    "annotations",
    "dwell",
    "observer",
    "multi-dom",
    "headless-ui",
    "compound-components"
  ]
}
